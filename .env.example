# SDK Configuration
SDK_BASE_URL=https://api.example.com
SDK_API_KEY=your-api-key-here
SDK_ENV=development
SDK_DEBUG=false

# HTTP Configuration
SDK_HTTP_TIMEOUT=30
SDK_HTTP_CONNECT_TIMEOUT=10
SDK_HTTP_MAX_REDIRECTS=5

# Retry Configuration
SDK_RETRY_MAX_ATTEMPTS=3
SDK_RETRY_INITIAL_BACKOFF_MS=100
SDK_RETRY_MAX_BACKOFF_MS=30000

# Cache Configuration
SDK_CACHE_ENABLED=true
SDK_CACHE_MAX_ENTRIES=1000
SDK_CACHE_TTL_SECS=3600

# Rate Limit Configuration
SDK_RATE_LIMIT_ENABLED=true
SDK_RATE_LIMIT_RPS=100
SDK_RATE_LIMIT_BURST=200

# Database Configuration
SDK_DATABASE_URL=sqlite://database.db
SDK_DATABASE_MAX_CONNECTIONS=10
SDK_DATABASE_CONNECTION_TIMEOUT=30
SDK_DATABASE_IDLE_TIMEOUT=300
